    {"name": "-ul", "long": null, "kind": "option", "metavar": "ULISTEN", "default": null, "repeatable": false, "description": "udp server setting uri"},
    {"name": "-ur", "long": null, "kind": "option", "metavar": "URSERVER", "default": "direct", "repeatable": true, "description": "udp remote server uri"},
    {"name": "-b", "long": null, "kind": "option", "metavar": "BLOCK", "default": null, "repeatable": true, "description": "block regex rules"},
    {"name": "-a", "long": null, "kind": "option", "metavar": "ALIVED", "default": null, "repeatable": false, "description": "interval to check remote alive"},
